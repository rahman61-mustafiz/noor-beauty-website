# Copy this file to ".env.local" and fill in your real Supabase values.
# Find them in Supabase: Project Settings > API.
# .env.local is gitignored — your keys stay private. NEVER commit real keys.

# Project URL (safe to expose — used in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# anon / public key (safe to expose — used in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# service_role key — SECRET. Server-side only. NEVER share or expose client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
